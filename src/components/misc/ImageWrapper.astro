---
import path from "node:path";
import { Image } from "astro:assets";
import { url } from "../../utils/url-utils";
import { siteConfig } from "@/config";

interface Props {
	id?: string;
	src: string;
	class?: string;
	alt?: string;
	position?: string;
	basePath?: string;
	videoSrc?: string;
}

const { id, src, alt, position = "center", basePath = "/", videoSrc } = Astro.props;
const className = Astro.props.class;

const isLivePhoto = siteConfig.livephoto && videoSrc;

const isLocal = !(
	src.startsWith("/") ||
	src.startsWith("http") ||
	src.startsWith("https") ||
	src.startsWith("data:")
);
const isPublic = src.startsWith("/");

// TODO temporary workaround for images dynamic import
// https://github.com/withastro/astro/issues/3373
// biome-ignore lint/suspicious/noImplicitAnyLet: <check later>
let img;
if (isLocal && src?.trim()) {
	const files = import.meta.glob<ImageMetadata>("../../**", {
		import: "default",
	});
	let normalizedPath = path
		.normalize(path.join("../../", basePath, src))
		.replace(/\\/g, "/");
	const file = files[normalizedPath];
	if (!file) {
		console.error(
			`\n[ERROR] Image file not found: ${normalizedPath.replace("../../", "src/")}`,
		);
	}
	img = await file();
}

const imageClass = "w-full h-full object-cover";
const imageStyle = `object-position: ${position}`;
---
<div id={id}
     class:list={[className, 'overflow-hidden relative', isLivePhoto ? 'live-photo-wrapper' : '']}
     data-photo-src={isLivePhoto ? (isPublic ? url(src) : src) : null}
     data-video-src={isLivePhoto ? (isPublic ? url(videoSrc) : videoSrc) : null}
>
    <div class="transition absolute inset-0 dark:bg-black/10 bg-opacity-50 pointer-events-none z-10"></div>
    {!isLivePhoto && isLocal && img && <Image src={img} alt={alt || ""} class={imageClass} style={imageStyle}/>}
    {!isLivePhoto && !isLocal && src && <img src={isPublic ? url(src) : src} alt={alt || ""} class={imageClass} style={imageStyle}/>}
</div>
